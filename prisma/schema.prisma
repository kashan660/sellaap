generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique
  password            String?
  name                String?
  mobile              String?
  role                String                @default("USER")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  orders              Order[]
  posts               Post[]                @relation("PostAuthor")
  pages               Page[]                @relation("PageAuthor")
  images              Image[]               @relation("ImageUploader")
  passwordResetTokens PasswordResetToken[]
  subscription        Subscription?
}

// Sellaap+ membership: a recurring Paddle subscription that gives the
// customer a discount on every order. One active row per user - see
// getActiveDiscountPercent() in lib/membership/tiers.ts for how the tier
// maps to a discount, and the Paddle webhook handler for lifecycle updates.
model Subscription {
  id                     Int       @id @default(autoincrement())
  userId                 Int       @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                   String // 'starter' | 'pro' | 'advanced'
  billingPeriod          String // 'month' | 'year'
  status                 String    @default("active") // active | past_due | paused | canceled
  paddleSubscriptionId   String    @unique
  paddleCustomerId       String
  paddlePriceId          String
  scheduledCancelAt      DateTime?
  currentBillingPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([paddleSubscriptionId])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id          Int        @id @default(autoincrement())
  slug        String     @unique
  name        String
  description String?
  image       String?
  parentId    Int?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  products    Product[]

  @@index([parentId])
}

model Product {
  id                   Int             @id @default(autoincrement())
  slug                 String          @unique
  name                 String
  description          String
  price                Float
  currency             String          @default("USD")
  paddlePriceId        String?
  categoryId           Int?
  features             String?
  fallbackImage        String
  image                String?
  isFeatured           Boolean         @default(false)
  isBestseller         Boolean         @default(false)
  compareAtPrice       Float?
  digitalFileUrl       String?
  digitalFileName      String?
  digitalFileSize      Int?
  digitalFileMimeType  String?
  sourceType           String          @default("MANUAL")
  cjProductId          String?
  cjVariantId          String?         @unique
  sku                  String?
  costPrice            Float?
  stockQuantity        Int             @default(0)
  weight               Float?
  lastSyncedAt         DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  orderItems           OrderItem[]
  category             Category?       @relation(fields: [categoryId], references: [id])
  regionalAvailability ProductRegion[]
  images               ProductImage[]
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, order])
}

model ProductRegion {
  id        Int      @id @default(autoincrement())
  productId Int
  region    String
  available Boolean  @default(true)
  price     Float?
  currency  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, region])
}

model SeoSettings {
  id                 Int      @id @default(autoincrement())
  siteTitle          String?
  siteDescription    String?
  defaultKeywords    String?
  twitterHandle      String?
  ogImage            String?
  googleVerification String?
  bingVerification   String?
  whatsappNumber     String?
  facebookUrl        String?
  instagramUrl       String?
  youtubeUrl         String?
  tiktokUrl          String?
  telegramUrl        String?
  updatedAt          DateTime @updatedAt
}

model PageSeo {
  id          Int      @id @default(autoincrement())
  path        String   @unique
  title       String?
  description String?
  keywords    String?
  ogImage     String?
  updatedAt   DateTime @updatedAt
}

model Page {
  id              Int        @id @default(autoincrement())
  slug            String     @unique
  title           String
  content         String
  excerpt         String?
  status          PageStatus @default(DRAFT)
  template        String     @default("default")
  authorId        Int?
  author          User?      @relation("PageAuthor", fields: [authorId], references: [id])
  featuredImageId Int?
  featuredImage   Image?     @relation("PageFeaturedImage", fields: [featuredImageId], references: [id])
  images          Image[]    @relation("PageImages")
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  parentId        Int?
  parent          Page?      @relation("PageHierarchy", fields: [parentId], references: [id])
  children        Page[]     @relation("PageHierarchy")
  order           Int        @default(0)
  views           Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  publishedAt     DateTime?
  
  @@index([status, slug])
  @@index([parentId, order])
}

enum PageStatus {
  DRAFT
  PUBLISHED
  PRIVATE
  ARCHIVED
}

model Image {
  id          Int      @id @default(autoincrement())
  filename    String
  originalName String
  mimeType    String
  size        Int
  url         String   @unique
  alt         String?
  caption     String?
  uploadedBy  Int
  uploader    User     @relation("ImageUploader", fields: [uploadedBy], references: [id])
  pages       Page[]   @relation("PageImages")
  posts       Post[]
  featuredPages Page[] @relation("PageFeaturedImage")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([uploadedBy])
}

model Post {
  id              Int          @id @default(autoincrement())
  slug            String       @unique
  title           String
  excerpt         String
  content         String
  date            DateTime     @default(now())
  category        String
  keywords        String
  imageUrl        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  metaDescription String?
  metaTitle       String?
  status          PostStatus   @default(DRAFT)
  authorId        Int?
  author          User?        @relation("PostAuthor", fields: [authorId], references: [id])
  images          Image[]
  tags            PostTag[]
  views           Int          @default(0)
  featured        Boolean      @default(false)
  
  @@index([status, date])
  @@index([category])
  @@index([featured])
}

model Tag {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?   @default("#3B82F6")
  posts       PostTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([slug])
}

model PostTag {
  id     Int    @id @default(autoincrement())
  postId Int
  tagId  Int
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Order {
  id                 Int         @id @default(autoincrement())
  userId             Int?
  total              Float
  currency           String      @default("USD")
  status             String      @default("PENDING")
  paymentMethod      String?
  shippingName       String?
  shippingPhone      String?
  shippingAddress1   String?
  shippingAddress2   String?
  shippingCity       String?
  shippingState      String?
  shippingPostalCode String?
  shippingCountry    String      @default("US")
  cjOrderId          String?
  fulfillmentStatus  String      @default("UNFULFILLED")
  trackingNumber     String?
  trackingCarrier    String?
  shippedAt          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User?       @relation(fields: [userId], references: [id])
  items              OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model PaddleProductMap {
  id              Int      @id @default(autoincrement())
  productId       Int      @unique
  paddleProductId String
  paddlePriceId   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
}

model PaymentSettings {
  id                Int      @id @default(autoincrement())
  paypalEmail       String?
  isPaypalEnabled   Boolean  @default(false)
  payoneerDetails   String?
  isPayoneerEnabled Boolean  @default(false)
  wiseDetails       String?
  isWiseEnabled     Boolean  @default(false)
  btcAddress        String?
  isBtcEnabled      Boolean  @default(false)
  binancePayId      String?
  isBinanceEnabled  Boolean  @default(false)
  usdtAddress       String?
  isUsdtEnabled     Boolean  @default(false)
  updatedAt         DateTime @updatedAt
}

model CjAuthToken {
  id                    Int      @id @default(autoincrement())
  accessToken           String   @db.Text
  accessTokenExpiresAt  DateTime
  refreshToken          String   @db.Text
  refreshTokenExpiresAt DateTime
  updatedAt             DateTime @updatedAt
}

model DropshipSettings {
  id            Int      @id @default(autoincrement())
  markupPercent Float    @default(30)
  autoFulfill   Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model Menu {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  location  String?    @unique // e.g., "header", "footer"
  items     MenuItem[]
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id        Int      @id @default(autoincrement())
  menuId    Int
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label     String
  url       String
  target    String   @default("_self")
  parentId  Int?
  parent    MenuItem? @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuHierarchy")
  order     Int      @default(0)
  
  @@index([menuId, order])
}

model Redirect {
  id          Int      @id @default(autoincrement())
  source      String   @unique
  destination String
  permanent   Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  @@index([source])
}
