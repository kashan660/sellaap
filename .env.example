# Database (MySQL)
DATABASE_URL="mysql://user:password@host:3306/database"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret"

# Google OAuth (Sign in with Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# CJ Dropshipping
CJ_API_KEY=""
CJ_SHOP_ID=""
CRON_SECRET="generate-a-random-secret-for-vercel-cron"

# Paddle - one-time checkout (physical goods orders)
# PADDLE_ENV must be exactly "sandbox" or "live" - never leave unset.
PADDLE_ENV="sandbox"
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
PADDLE_AUTO_SYNC="true"

# Paddle - client-side (Sellaap+ membership checkout + one-time checkout overlay)
# NEXT_PUBLIC_ vars are exposed to the browser - never put secrets here.
# NEXT_PUBLIC_PADDLE_ENV must be exactly "sandbox" or "live"/"production".
NEXT_PUBLIC_PADDLE_ENV="sandbox"
# Sandbox tokens start with test_, live tokens start with live_.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""

# Site URL used for absolute links in emails / metadata
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (password reset, etc.)
RESEND_API_KEY=""
EMAIL_FROM=""

# File uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=""

# Optional affiliate program IDs (legacy)
NEXT_PUBLIC_AMAZON_ASSOCIATE_ID=""
NEXT_PUBLIC_ENVATO_AFFILIATE_ID=""
NEXT_PUBLIC_GUMROAD_AFFILIATE_ID=""
NEXT_PUBLIC_IMPACT_CLIENT_ID=""
IMPACT_API_KEY=""
